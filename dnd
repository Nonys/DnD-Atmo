#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# ── colours ──────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

ok()   { echo -e "  ${GREEN}✓${NC}  $1"; }
fail() { echo -e "  ${RED}✗${NC}  $1"; ERRORS=$((ERRORS + 1)); }
warn() { echo -e "  ${YELLOW}!${NC}  $1"; }
info() { echo -e "     ${CYAN}→${NC} $1"; }
hr()   { echo -e "${CYAN}──────────────────────────────────────────${NC}"; }

ERRORS=0

# ────────────────────────────────────────────────────────────
cmd_run() {
    echo ""
    echo -e "${BOLD}DnD Atmosphere Generator${NC}"
    hr

    # 1. Docker ------------------------------------------------
    echo -e "\n${BOLD}Docker${NC}"
    if command -v docker &>/dev/null; then
        ok "Docker installed ($(docker --version | cut -d' ' -f3 | tr -d ','))"
    else
        fail "Docker not found"
        info "Install Docker: https://docs.docker.com/get-docker/"
    fi

    if docker info &>/dev/null 2>&1; then
        ok "Docker daemon running"
    else
        fail "Docker daemon is not running"
        info "Start Docker and retry"
    fi

    if docker compose version &>/dev/null 2>&1; then
        ok "Docker Compose available"
    else
        fail "Docker Compose not found (needs v2+)"
    fi

    # Bail early — nothing else makes sense without Docker
    if [ $ERRORS -gt 0 ]; then
        _abort
    fi

    # 2. .env / API key ----------------------------------------
    echo -e "\n${BOLD}Configuration${NC}"
    if [ ! -f ".env" ]; then
        fail ".env not found"
        info "cp .env.example .env  — then set OPENAI_API_KEY"
    else
        ok ".env exists"
        # Extract key without sourcing (avoids side effects)
        local key
        key=$(grep -E '^OPENAI_API_KEY=' .env | head -1 | cut -d'=' -f2- | tr -d '"'"'" | xargs)
        if [ -z "$key" ] || [ "$key" = "sk-...your-key-here..." ]; then
            fail "OPENAI_API_KEY is not set in .env"
            info "Edit .env and paste your key from platform.openai.com"
        elif [[ "$key" == sk-* ]] || [[ "$key" == sk-proj-* ]]; then
            ok "OPENAI_API_KEY looks valid (${key:0:8}…)"
        else
            warn "OPENAI_API_KEY set but doesn't look like an sk- key — continuing anyway"
        fi
    fi

    # 3. Whisper model -----------------------------------------
    echo -e "\n${BOLD}Whisper model${NC}"
    if [ -f "models/ggml-model.bin" ]; then
        local size
        size=$(du -sh models/ggml-model.bin | cut -f1)
        ok "Model found  (${size})"
    else
        warn "No model at models/ggml-model.bin"
        info "Transcription will be skipped (image generation still works)"
        info "To download:  ./dnd model"
    fi

    # 4. Runtime directories -----------------------------------
    echo -e "\n${BOLD}Directories${NC}"
    mkdir -p public/sessions data
    ok "public/sessions/ ready"
    ok "data/ ready"

    # 5. Hard errors? ------------------------------------------
    if [ $ERRORS -gt 0 ]; then
        _abort
    fi

    # 6. Launch ------------------------------------------------
    hr
    echo -e "\n${GREEN}All checks passed.${NC} Starting...\n"
    echo -e "  ${CYAN}→${NC} http://localhost:8080"
    echo -e "  ${CYAN}→${NC} http://$(hostname -I | awk '{print $1}'):8080  (LAN)"
    echo ""

    docker compose up --build
}

# ────────────────────────────────────────────────────────────
cmd_stop() {
    echo -e "\n${BOLD}Stopping DnD Atmosphere...${NC}"
    docker compose down
    echo -e "${GREEN}Stopped.${NC}\n"
}

# ────────────────────────────────────────────────────────────
cmd_logs() {
    docker compose logs -f --tail=50
}

# ────────────────────────────────────────────────────────────
cmd_model() {
    local model="${1:-medium}"
    local url filename

    case "$model" in
        tiny)   filename="ggml-tiny.bin"   ;;
        base)   filename="ggml-base.bin"   ;;
        small)  filename="ggml-small.bin"  ;;
        medium) filename="ggml-medium.bin" ;;
        large)  filename="ggml-large-v3.bin" ;;
        *)
            echo -e "${RED}Unknown model '$model'.${NC}"
            echo "  Available: tiny | base | small | medium | large"
            exit 1
            ;;
    esac

    url="https://huggingface.co/ggerganov/whisper.cpp/resolve/main/${filename}"
    local dest="models/ggml-model.bin"

    mkdir -p models
    echo -e "\n${BOLD}Downloading Whisper model: ${model}${NC}"
    echo -e "  Source: ${url}"
    echo -e "  Dest:   ${dest}\n"

    if command -v wget &>/dev/null; then
        wget --show-progress -O "$dest" "$url"
    elif command -v curl &>/dev/null; then
        curl -L --progress-bar -o "$dest" "$url"
    else
        echo -e "${RED}Neither wget nor curl found.${NC}"
        exit 1
    fi

    local size
    size=$(du -sh "$dest" | cut -f1)
    echo -e "\n${GREEN}Model downloaded (${size}).${NC}\n"
}

# ────────────────────────────────────────────────────────────
_abort() {
    echo ""
    hr
    echo -e "${RED}Startup aborted — fix the errors above and retry:${NC}  dnd run"
    echo ""
    exit 1
}

_usage() {
    echo ""
    echo -e "${BOLD}Usage:${NC}  dnd <command>"
    echo ""
    echo "  run              Check setup and start the app"
    echo "  stop             Stop containers"
    echo "  logs             Tail container logs"
    echo "  model [size]     Download a Whisper model (tiny/base/small/medium/large)"
    echo "                   Default: medium — recommended for Czech"
    echo ""
}

# ────────────────────────────────────────────────────────────
case "${1:-}" in
    run)   cmd_run ;;
    stop)  cmd_stop ;;
    logs)  cmd_logs ;;
    model) cmd_model "${2:-medium}" ;;
    *)     _usage ;;
esac
